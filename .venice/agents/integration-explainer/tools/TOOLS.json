    "web_search": {
      "name": "Web Search",
      "description": "Search the web for updated documentation, solutions, and best practices",
      "capabilities": [
        "Search for API documentation updates",
        "Find error solutions and troubleshooting guides",
        "Discover new best practices and patterns",
        "Check for security vulnerability updates",
        "Find performance optimization techniques",
        "Search for community discussions and forums",
        "Find official GitHub repositories and issues",
        "Discover recent blog posts and tutorials"
      ],
      "search_engines": ["Google", "GitHub", "Stack Overflow", "MDN", "npm", "official_docs"],
      "filter_options": {
        "time_range": ["past_hour", "past_day", "past_week", "past_month", "past_year"],
        "source_type": ["official_docs", "tutorials", "forums", "code_repositories", "blog_posts"],
        "relevance_score": 0.8
      },
      "validation_checks": [
        "Check publication date",
        "Verify source credibility",
        "Cross-reference multiple sources",
        "Check for official documentation",
        "Verify with community consensus"
      ]
    },
    "configuration_validator": {
      "name": "Configuration Validator",
      "description": "Validate configuration files and environment setups",
      "capabilities": [
        "Validate .env files for missing variables",
        "Check package.json for dependency conflicts",
        "Validate Dockerfile and docker-compose.yml",
        "Check Next.js configuration (next.config.js)",
        "Validate TypeScript configuration (tsconfig.json)",
        "Check Tailwind configuration (tailwind.config.js)",
        "Validate ESLint configuration (.eslintrc.js)",
        "Check CI/CD configuration files"
      ],
      "config_file_types": [
        ".env",
        "package.json",
        "tsconfig.json",
        "next.config.js",
        "tailwind.config.js",
        ".eslintrc.js",
        "Dockerfile",
        "docker-compose.yml",
        "github/workflows/*.yml",
        "vercel.json"
      ],
      "validation_rules": {
        "environment_variables": {
          "required_variables": ["NEXT_PUBLIC_API_URL", "DATABASE_URL", "API_KEY"],
          "sensitive_variables": ["API_KEY", "SECRET_KEY", "JWT_SECRET"],
          "format_validation": ["URL", "EMAIL", "HEX_COLOR", "BOOLEAN"]
        },
        "dependencies": {
          "version_conflicts": true,
          "security_vulnerabilities": true,
          "deprecated_packages": true,
          "peer_dependencies": true
        }
      }
    },
    "documentation_generator": {
      "name": "Documentation Generator",
      "description": "Generate comprehensive documentation for integrations",
      "capabilities": [
        "Generate API documentation from OpenAPI/Swagger",
        "Create README files with installation instructions",
        "Generate code documentation with JSDoc/TypeDoc",
        "Create architecture decision records (ADRs)",
        "Generate troubleshooting guides",
        "Create deployment documentation",
        "Generate security compliance documentation",
        "Create performance optimization guides"
      ],
      "output_formats": ["markdown", "html", "pdf", "confluence", "notion"],
      "templates": {
        "api_docs": {
          "endpoints": true,
          "parameters": true,
          "responses": true,
          "examples": true,
          "authentication": true,
          "error_codes": true
        },
        "readme": {
          "project_title": true,
          "description": true,
          "installation": true,
          "usage": true,
          "api_reference": true,
          "contributing": true,
          "license": true
        },
        "troubleshooting": {
          "problem_statement": true,
          "symptoms": true,
          "causes": true,
          "solutions": true,
          "prevention": true,
          "references": true
        }
      }
    },

        "error_rate",
        "cache_efficiency",
        "database_query_time",
        "memory_footprint",
        "cpu_utilization",
        "network_bandwidth"
      ],
      "optimization_recommendations": {
        "frontend": [
          "Code splitting",
          "Image optimization",
          "Lazy loading",
          "Bundle analysis",
          "Critical CSS extraction"
        ],
        "backend": [
          "Database indexing",
          "Query optimization",
          "Connection pooling",
          "Caching strategies",
          "Load balancing"
        ],
        "api": [
          "Request batching",
          "Response compression",
        "Pagination optimization",
          "CDN utilization",
          "Edge computing"
        ]
      }
    },
    "blockchain_integration_tester": {
      "name": "Blockchain Integration Tester",
      "description": "Test and validate blockchain integrations",
      "capabilities": [
        "Smart contract interaction testing",
        "Gas usage optimization analysis",
        "Wallet connection testing (WalletConnect v1/v2)",
        "Transaction simulation and validation",
        "Event listening and processing",
        "NFT minting flow testing",
        "Token transfer validation",
        "Cross-chain bridge testing"
      ],
      "blockchains_supported": [
        "Ethereum",
        "Base",
        "Polygon",
        "Arbitrum",
        "Optimism",
        "Solana",
        "Avalanche"
      ],
      "testing_environments": ["mainnet", "testnet", "local", "forked"],
      "tools_integrated": [

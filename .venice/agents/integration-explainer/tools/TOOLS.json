  "dependencies": {
    "external_apis": [
      {
        "name": "Venice.ai API",
        "version": "latest",
        "authentication": "API_KEY",
        "rate_limit": "per_token",
        "documentation": "https://docs.venice.ai"
      },
      {
        "name": "Coinbase onChainKit SDK",
        "version": "latest",
        "authentication": "WALLET_CONNECTION",
        "rate_limit": "per_wallet",
        "documentation": "https://docs.cloud.coinbase.com/onchainkit"
      },
      {
        "name": "Farcaster SDK",
        "version": "latest",
        "authentication": "API_KEY",
        "rate_limit": "per_key",
        "documentation": "https://docs.farcaster.xyz"
      },
      {
        "name": "Neynar API",
        "version": "v2",
        "authentication": "API_KEY",
        "rate_limit": "tier_based",
        "documentation": "https://docs.neynar.com"
      }
    ],
    "internal_tools": [
      {
        "name": "Memory System",
        "purpose": "Persistent storage for tool outputs",
        "access": "read_write"
      },
      {
        "name": "Context Manager",
        "purpose": "Maintain conversation context across tools",
        "access": "read_write"
      },
      {
        "name": "Error Handler",
        "purpose": "Standardized error handling across tools",
        "access": "read_only"
      }
    ]
  },
  "execution_policies": {
    "timeout_policy": "fail_after_300s",
    "retry_policy": "exponential_backoff_max_3",
    "concurrency_limit": 5,
    "rate_limit": "10_per_minute_per_tool",
    "cost_tracking": true,
    "privacy_mode": "no_pii_storage"
  }
}

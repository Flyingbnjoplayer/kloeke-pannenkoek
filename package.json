
{
  "name": "agent-trinity-platform",
  "version": "1.0.0",
  "description": "Multi-agent platform with Next.js 15, TanStack Query, and Venice.ai integration",
  "main": "next-env.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "db:backup": "node scripts/database/backup.js",
    "performance:audit": "node scripts/performance/audit.js",
    "security:scan": "npm audit --production && npm audit --dev",
    "build:docker": "docker build -t agent-trinity .",
    "deploy:staging": "vercel --prod --prebuilt --confirm",
    "deploy:production": "vercel --prod --confirm --prebuilt"
  },
  "dependencies": {
    "@supabase/supabase-js": "^1^.38.0",
    "next": "14.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "typescript": "5.4.5",
    "venice-ai": "^2^.0.0",
    "onchainkit": "^2^.0.0",
    "farcaster": "^2^.0.0",
    "neynar": "^2^.0.0",
    "vercel": "^3^.0.0",
    "supabase": "^1^.38.0",
    "vercel-ai": "^2^.0.0",
    "tailwindcss": "^4^.0.0",
    "shadcn-ui": "^2^.0.0",
    "class-variance-authority": ".7.0",
    "@tanstack/react-query": "^5^.0.0",
    "@tanstack/router": "^1^.0.0",
    "@tanstack/form": "^1^.0.0",
    "vercel": "^3^.0.0",
    "vercel-ai": "^2^.0.0"
  },
  "devDependencies": {
    "@types/node": "20.12.7",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "5.4.5",
    "eslint": "^6^.0.0",
    "eslint-config-next": "14.2.3",
    "jest": "^7^.7.0",
    "ts-jest": "^7^.2.3",
    "supertest": "^8^.0.0",
    "cypress": "^9^.10.0",
    "prettier": "^10^.2.5",
    "husky": "^6^.0.0",
    "lint-staged": "^11^.0.0",
    "dotenv": "^12^.4.5",
    "vercel": "^3^.0.0",
    "vercel-ai": "^2^.0.0"
  },
  "keywords": ["agent", "multi-agent", "nextjs", "venice-ai", "web3"],
  "author": "Agent Trinity",
  "license": "MIT"
}
